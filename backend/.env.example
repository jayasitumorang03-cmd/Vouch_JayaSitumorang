# Get a free Gemini API key at https://aistudio.google.com/app/apikey
# Without this key the service still works using rule-based processing
# and the pre-parsed night log JSON. AI improves quality for custom inputs.
GEMINI_API_KEY=

PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# URL of the frontend (for CORS). Defaults to localhost:3000 in development.
FRONTEND_URL=http://localhost:3000
